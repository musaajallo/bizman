generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// --- Auth.js required models ---

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  isSuperAdmin  Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts    Account[]
  sessions    Session[]
  tenantUsers TenantUser[]
  auditLogs   AuditLog[]

  // Projects
  createdProjects    Project[]
  projectMembers     ProjectMember[]
  assignedTasks      Task[]              @relation("TaskAssignee")
  createdTasks       Task[]              @relation("TaskCreator")
  taskComments       TaskComment[]
  checklistItems     TaskChecklistItem[]
  projectActivities  ProjectActivity[]
  timeEntries        TimeEntry[]
  createdTemplates   ProjectTemplate[]

  // Invoicing
  createdInvoices    Invoice[]
  invoicePayments    InvoicePayment[]
  invoiceActivities  InvoiceActivity[]

  // Documents
  uploadedDocuments     Document[]
  documentVersions      DocumentVersion[]

  // Docs (Knowledge Base)
  createdDocPages       DocPage[]        @relation("DocPageCreator")
  lastEditedDocPages    DocPage[]        @relation("DocPageLastEditor")
  docRevisions          DocRevision[]

  // HR
  employees             Employee[]
  reviewedLeaveRequests LeaveRequest[]

  // Expenses
  submittedExpenses Expense[] @relation("ExpenseSubmitter")
  reviewedExpenses  Expense[] @relation("ExpenseReviewer")

  // Timesheets
  reviewedTimesheets Timesheet[] @relation("TimesheetReviewer")

  // Overtime settings
  overtimeSettingsLog OvertimeSettingsLog[]

  // Leave settings
  leaveSettingsLog LeaveSettingsLog[]

  // Procurement
  purchaseRequisitions         PurchaseRequisition[]  @relation("RequisitionRequester")
  reviewedRequisitions         PurchaseRequisition[]  @relation("RequisitionReviewer")
  createdPurchaseOrders        PurchaseOrder[]
  goodsReceipts                GoodsReceipt[]

  // Assets
  assetAssignments AssetAssignment[] @relation("AssetAssigner")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

// --- Multi-tenancy ---

model Tenant {
  id                  String   @id @default(cuid())
  name                String
  slug                String   @unique
  industry            String?
  address             String?
  website             String?
  primaryContactName  String?
  primaryContactEmail String?
  primaryContactPhone String?
  status              String   @default("active") // active, paused, archived
  notes               String?
  isOwnerBusiness     Boolean  @default(false)

  // Branding
  logoUrl       String?
  primaryColor  String?
  accentColor   String?
  fontFamily    String?
  headerLayout  String?  // left, center, right
  footerText    String?
  pdfWatermark  String?

  // Modules
  enabledModules String[] @default(["hr", "forms", "pdf"])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenantUsers   TenantUser[]
  forms         Form[]
  profiles      Profile[]
  auditLogs     AuditLog[]
  notifications Notification[]

  // Projects
  projects          Project[]
  clientProjects    Project[]         @relation("ProjectClient")
  projectCategories ProjectCategory[]
  projectTemplates  ProjectTemplate[]

  // Invoicing
  invoiceSettings   InvoiceSettings?
  invoices          Invoice[]
  clientInvoices    Invoice[]         @relation("InvoiceClient")
  taxProfiles       TaxProfile[]

  // Communications
  smtpSettings      SmtpSettings?

  // Documents
  documents         Document[]

  // Docs (Knowledge Base)
  docPages          DocPage[]

  // Statutory Registers
  directors         Director[]
  shareholders      Shareholder[]

  // HR
  employees         Employee[]
  leaveBalances     LeaveBalance[]
  leaveRequests     LeaveRequest[]
  leaveSettings     LeaveSettings?
  leaveSettingsLog  LeaveSettingsLog[]

  // Payroll
  payrollRuns       PayrollRun[]
  payslips          Payslip[]

  // Expenses
  expenses          Expense[]

  // Bills & Vendors
  vendors      Vendor[]
  bills        Bill[]
  billPayments BillPayment[]
  billSettings BillSettings?

  // Timesheets
  timesheets Timesheet[]

  // Overtime
  overtimeRequests    OvertimeRequest[]
  overtimeSettings    OvertimeSettings?
  overtimeSettingsLog OvertimeSettingsLog[]

  // Procurement
  purchaseRequisitions PurchaseRequisition[]
  purchaseOrders       PurchaseOrder[]
  goodsReceipts        GoodsReceipt[]
  procurementSettings  ProcurementSettings?

  // Assets
  assets        Asset[]
  assetSettings AssetSettings?
}

model TenantUser {
  id       String @id @default(cuid())
  tenantId String
  userId   String
  role     String // company_admin, manager, staff

  modulePermissions Json? // [{module, access}]

  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId])
}

// --- Forms ---

model Form {
  id               String   @id @default(cuid())
  tenantId         String
  name             String
  slug             String
  description      String?
  status           String   @default("draft") // draft, published, archived
  pdfLayout        String?  // single, two-column
  showPhoto        Boolean  @default(false)
  photoPosition    String?  // top-left, top-right
  requireSignature Boolean  @default(false)
  successMessage   String?
  redirectUrl      String?
  expiryDate       DateTime?
  submissionLimit  Int?
  createdById      String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  fields FormField[]
  profiles Profile[]

  @@unique([tenantId, slug])
}

model FormField {
  id               String   @id @default(cuid())
  formId           String
  type             String
  label            String
  placeholder      String?
  helperText       String?
  required         Boolean  @default(false)
  width            String   @default("full") // full, half
  order            Int
  validation       Json?
  options          String[]
  tableColumns     Json?
  defaultRowCount  Int?
  pdfVisible       Boolean  @default(true)
  pdfLabelOverride String?

  form Form @relation(fields: [formId], references: [id], onDelete: Cascade)
}

// --- Profiles ---

model Profile {
  id                 String  @id @default(cuid())
  tenantId           String
  formId             String
  data               Json
  status             String  @default("submitted") // submitted, reviewed, filed
  photoUrl           String?
  signatureUrl       String?
  pdfUrl             String?
  submittedById      String?
  referenceNumber    String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  form   Form   @relation(fields: [formId], references: [id], onDelete: Cascade)
}

// --- Audit Logs ---

model AuditLog {
  id         String   @id @default(cuid())
  tenantId   String?
  actorId    String
  action     String
  entityType String
  entityId   String
  before     Json?
  after      Json?
  timestamp  DateTime @default(now())

  tenant Tenant? @relation(fields: [tenantId], references: [id])
  actor  User    @relation(fields: [actorId], references: [id])
}

// --- Notifications ---

model Notification {
  id         String   @id @default(cuid())
  userId     String
  tenantId   String?
  type       String
  title      String
  message    String
  entityType String?
  entityId   String?
  read       Boolean  @default(false)
  createdAt  DateTime @default(now())

  tenant Tenant? @relation(fields: [tenantId], references: [id])
}

// --- Project Categories ---

model ProjectCategory {
  id       String @id @default(cuid())
  tenantId String
  name     String
  order    Int    @default(0)

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  projects Project[]

  @@unique([tenantId, name])
  @@index([tenantId, order])
}

// --- Projects ---

model Project {
  id          String    @id @default(cuid())
  tenantId    String
  name        String
  slug        String
  description String?   @db.Text
  status      String    @default("not_started") // not_started, in_progress, on_hold, completed, cancelled
  priority    String    @default("medium") // low, medium, high, urgent
  type        String    @default("client") // client, internal, retainer

  // Client type: internal, individual, organization
  clientType String @default("organization")

  // Dates
  startDate DateTime?
  endDate   DateTime?
  isRolling Boolean   @default(false)

  // Entity assignment — Individual
  contactName    String?
  contactEmail   String?
  contactPhone   String?

  // Entity assignment — Organization
  clientTenantId String?
  orgName        String?
  orgAddress     String?
  orgContactName  String?
  orgContactEmail String?
  orgContactPhone String?

  // Budget
  billingType    String? // fixed, hourly, retainer, pro_bono
  budgetAmount   Decimal? @db.Decimal(12, 2)
  budgetCurrency String?
  hourlyRate     Decimal? @db.Decimal(8, 2)

  // Categorization
  categoryId String?
  tags       String[]

  // Progress
  progress Int @default(0)

  // Notes
  notes String? @db.Text

  // Metadata
  createdById String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  archivedAt  DateTime?

  tenant       Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  clientTenant Tenant?          @relation("ProjectClient", fields: [clientTenantId], references: [id], onDelete: SetNull)
  category     ProjectCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  createdBy    User             @relation(fields: [createdById], references: [id])
  members      ProjectMember[]
  tasks        Task[]
  statuses     ProjectStatus[]
  milestones   Milestone[]
  activities   ProjectActivity[]
  invoices         Invoice[]
  timesheetEntries TimesheetEntry[]
  overtimeRequests OvertimeRequest[]

  @@unique([tenantId, slug])
  @@index([tenantId, status])
  @@index([clientTenantId])
  @@index([categoryId])
}

model ProjectMember {
  id        String   @id @default(cuid())
  projectId String
  userId    String
  role      String   @default("member") // lead, member, reviewer
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
}

model ProjectStatus {
  id        String  @id @default(cuid())
  projectId String
  name      String
  color     String  @default("#6B7280")
  group     String  // not_started, active, done, closed
  order     Int
  isDefault Boolean @default(false)

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks   Task[]

  @@unique([projectId, name])
  @@index([projectId, order])
}

model Task {
  id          String   @id @default(cuid())
  projectId   String
  statusId    String
  parentId    String?
  title       String
  description String?  @db.Text
  priority    String   @default("medium") // none, low, medium, high, urgent
  order       Int      @default(0)

  assigneeId  String?
  startDate   DateTime?
  dueDate     DateTime?
  completedAt DateTime?

  estimateMinutes Int?
  loggedMinutes   Int @default(0)

  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project  Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  status   ProjectStatus @relation(fields: [statusId], references: [id])
  parent   Task?         @relation("TaskSubtasks", fields: [parentId], references: [id], onDelete: Cascade)
  subtasks Task[]        @relation("TaskSubtasks")
  assignee User?         @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  createdBy User         @relation("TaskCreator", fields: [createdById], references: [id])
  comments   TaskComment[]
  checklists TaskChecklist[]

  // Dependencies
  blockedBy TaskDependency[] @relation("DependencyBlockedTask")
  blocking  TaskDependency[] @relation("DependencyBlockingTask")

  // Time entries
  timeEntries TimeEntry[]

  @@index([projectId, statusId, order])
  @@index([assigneeId])
  @@index([parentId])
}

model TaskComment {
  id        String   @id @default(cuid())
  taskId    String
  authorId  String
  content   String   @db.Text
  parentId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  task    Task          @relation(fields: [taskId], references: [id], onDelete: Cascade)
  author  User          @relation(fields: [authorId], references: [id])
  parent  TaskComment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies TaskComment[] @relation("CommentReplies")

  @@index([taskId, createdAt])
}

model TaskChecklist {
  id     String @id @default(cuid())
  taskId String
  title  String @default("Checklist")
  order  Int    @default(0)

  task  Task                @relation(fields: [taskId], references: [id], onDelete: Cascade)
  items TaskChecklistItem[]

  @@index([taskId, order])
}

model TaskChecklistItem {
  id          String   @id @default(cuid())
  checklistId String
  title       String
  isComplete  Boolean  @default(false)
  order       Int      @default(0)
  assigneeId  String?
  createdAt   DateTime @default(now())

  checklist TaskChecklist @relation(fields: [checklistId], references: [id], onDelete: Cascade)
  assignee  User?         @relation(fields: [assigneeId], references: [id], onDelete: SetNull)

  @@index([checklistId, order])
}

// --- Milestones ---

model Milestone {
  id          String    @id @default(cuid())
  projectId   String
  name        String
  description String?
  dueDate     DateTime?
  completed   Boolean   @default(false)
  completedAt DateTime?
  order       Int       @default(0)
  createdAt   DateTime  @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, order])
}

// --- Project Activity Log ---

model ProjectActivity {
  id        String   @id @default(cuid())
  projectId String
  actorId   String
  action    String   // created_project, updated_status, added_member, removed_member, created_task, completed_task, created_milestone, completed_milestone, updated_project, etc.
  details   Json?    // { field, from, to } or { taskTitle, memberName, milestoneName }
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  actor   User    @relation(fields: [actorId], references: [id])

  @@index([projectId, createdAt])
}

// --- Task Dependencies ---

model TaskDependency {
  id             String @id @default(cuid())
  taskId         String // The blocked task
  dependsOnId    String // The blocking task
  type           String @default("finish_to_start") // finish_to_start, start_to_start, finish_to_finish, start_to_finish

  createdAt DateTime @default(now())

  task      Task @relation("DependencyBlockedTask", fields: [taskId], references: [id], onDelete: Cascade)
  dependsOn Task @relation("DependencyBlockingTask", fields: [dependsOnId], references: [id], onDelete: Cascade)

  @@unique([taskId, dependsOnId])
  @@index([dependsOnId])
}

// --- Time Tracking ---

model TimeEntry {
  id          String   @id @default(cuid())
  taskId      String
  userId      String
  minutes     Int
  description String?
  date        DateTime @default(now())
  createdAt   DateTime @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id])

  @@index([taskId])
  @@index([userId, date])
}

// --- Project Templates ---

model ProjectTemplate {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  description String?
  category    String?
  statuses    Json     // Array of { name, color, group, order, isDefault }
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant    Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy User                  @relation(fields: [createdById], references: [id])
  tasks     ProjectTemplateTask[]

  @@index([tenantId])
}

model ProjectTemplateTask {
  id          String  @id @default(cuid())
  templateId  String
  parentId    String?
  title       String
  description String? @db.Text
  priority    String  @default("medium")
  statusIndex Int     @default(0) // Index into template's statuses array
  order       Int     @default(0)

  template ProjectTemplateTask? @relation("TemplateTaskSubtasks", fields: [parentId], references: [id], onDelete: Cascade)
  subtasks ProjectTemplateTask[] @relation("TemplateTaskSubtasks")
  parent   ProjectTemplate      @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([templateId, order])
}

// --- Invoicing ---

model InvoiceSettings {
  id                String   @id @default(cuid())
  tenantId          String   @unique
  prefix            String   @default("INV")
  nextNumber        Int      @default(1)
  defaultDueDays    Int      @default(30)
  defaultNotes      String?  @db.Text
  defaultTerms      String?  @db.Text
  bankName          String?
  bankAccountName   String?
  bankAccountNumber String?
  bankRoutingNumber String?
  bankSwift         String?
  bankIban          String?
  taxLabel          String?  @default("Tax")
  defaultTaxRate    Decimal? @db.Decimal(5, 2)
  proformaPrefix    String   @default("PRO")
  proformaNextNumber Int     @default(1)
  creditNotePrefix     String @default("CN")
  creditNoteNextNumber Int    @default(1)

  // Invoice branding (overrides tenant primaryColor)
  accentColor String?
  logoUrl     String?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model TaxProfile {
  id          String   @id @default(cuid())
  tenantId    String
  name        String   // "VAT (15%)", "GST (10%)"
  rate        Decimal  @db.Decimal(5, 2)
  description String?
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, name])
  @@index([tenantId])
}

// --- Communications ---

model SmtpSettings {
  id         String  @id @default(cuid())
  tenantId   String  @unique
  host       String?
  port       Int     @default(587)
  username   String?
  password   String? @db.Text
  encryption String  @default("tls") // tls, ssl, none
  fromName   String?
  fromEmail  String?
  replyTo    String?
  enabled    Boolean @default(false)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model Invoice {
  id              String    @id @default(cuid())
  tenantId        String
  projectId       String?
  clientTenantId  String?

  invoiceNumber   String
  referenceNumber String?

  // standard (payment request) or proforma (estimate/quote)
  type            String    @default("standard")

  // draft, sent, viewed, paid, overdue, void (standard)
  // draft, sent, viewed, accepted, converted, expired, void (proforma)
  status          String    @default("draft")

  issueDate       DateTime  @default(now())
  dueDate         DateTime
  paidDate        DateTime?
  sentAt          DateTime?
  viewedAt        DateTime?
  voidedAt        DateTime?

  // Client snapshot
  clientName      String
  clientEmail     String?
  clientPhone     String?
  clientAddress   String?

  // Amounts
  subtotal        Decimal   @db.Decimal(12, 2) @default(0)
  taxRate         Decimal?  @db.Decimal(5, 2)
  taxAmount       Decimal   @db.Decimal(12, 2) @default(0)
  discountAmount  Decimal   @db.Decimal(12, 2) @default(0)
  total           Decimal   @db.Decimal(12, 2) @default(0)
  amountPaid      Decimal   @db.Decimal(12, 2) @default(0)
  amountDue       Decimal   @db.Decimal(12, 2) @default(0)
  currency        String    @default("USD")

  notes           String?   @db.Text
  terms           String?   @db.Text

  shareToken      String    @unique @default(cuid())
  pdfUrl          String?

  // Recurring
  isRecurring       Boolean   @default(false)
  recurringInterval String?
  nextRecurringDate DateTime?
  parentInvoiceId   String?

  // Proforma conversion tracking
  convertedFromId   String?   @unique

  // Credit note tracking
  creditNoteForId   String?

  createdById     String
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  tenant        Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  project       Project?         @relation(fields: [projectId], references: [id], onDelete: SetNull)
  clientTenant  Tenant?          @relation("InvoiceClient", fields: [clientTenantId], references: [id], onDelete: SetNull)
  parentInvoice Invoice?         @relation("RecurringInvoices", fields: [parentInvoiceId], references: [id], onDelete: SetNull)
  recurringChildren Invoice[]    @relation("RecurringInvoices")
  convertedFrom Invoice?         @relation("ProformaConversion", fields: [convertedFromId], references: [id], onDelete: SetNull)
  convertedTo   Invoice?         @relation("ProformaConversion")
  creditNoteFor Invoice?         @relation("CreditNoteFor", fields: [creditNoteForId], references: [id], onDelete: SetNull)
  creditNotes   Invoice[]        @relation("CreditNoteFor")
  createdBy     User             @relation(fields: [createdById], references: [id])
  lineItems     InvoiceLineItem[]
  payments      InvoicePayment[]
  appliedAsCredits InvoicePayment[] @relation("CreditNotePayment")
  activities    InvoiceActivity[]

  @@unique([tenantId, invoiceNumber])
  @@index([tenantId, type, status])
  @@index([projectId])
  @@index([clientTenantId])
  @@index([creditNoteForId])
  @@index([dueDate])
  @@index([shareToken])
}

model InvoiceLineItem {
  id          String  @id @default(cuid())
  invoiceId   String
  order       Int     @default(0)

  description String
  quantity    Decimal @db.Decimal(10, 2)
  unitPrice   Decimal @db.Decimal(12, 2)
  amount      Decimal @db.Decimal(12, 2)
  unit        String? // hours, days, units, fixed

  timeEntryIds String[]

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId, order])
}

model InvoicePayment {
  id           String   @id @default(cuid())
  invoiceId    String
  amount       Decimal  @db.Decimal(12, 2)
  method       String?  // bank_transfer, cash, check, card, mobile_money, other
  reference    String?
  notes        String?
  date         DateTime @default(now())
  recordedById String
  createdAt    DateTime @default(now())

  creditNoteId String?

  invoice    Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  recordedBy User     @relation(fields: [recordedById], references: [id])
  creditNote Invoice? @relation("CreditNotePayment", fields: [creditNoteId], references: [id], onDelete: SetNull)

  @@index([invoiceId])
  @@index([creditNoteId])
}

model InvoiceActivity {
  id        String   @id @default(cuid())
  invoiceId String
  actorId   String?
  action    String   // created, updated, sent, viewed, paid, partially_paid, voided, reminder_sent
  details   Json?
  createdAt DateTime @default(now())

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  actor   User?   @relation(fields: [actorId], references: [id])

  @@index([invoiceId, createdAt])
}

// --- Documents (File Storage) ---

model Document {
  id               String    @id @default(cuid())
  tenantId         String
  name             String
  slug             String
  description      String?   @db.Text
  folder           String    @default("/")
  tags             String[]
  currentVersionId String?
  uploadedById     String
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  archivedAt       DateTime?

  tenant       Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  uploadedBy   User              @relation(fields: [uploadedById], references: [id])
  versions     DocumentVersion[]

  @@unique([tenantId, slug])
  @@index([tenantId, folder])
}

model DocumentVersion {
  id           String   @id @default(cuid())
  documentId   String
  version      Int
  fileName     String
  fileUrl      String
  fileSize     Int
  mimeType     String
  changelog    String?
  uploadedById String
  createdAt    DateTime @default(now())

  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  uploadedBy User     @relation(fields: [uploadedById], references: [id])

  @@unique([documentId, version])
  @@index([documentId])
}

// --- Docs (Knowledge Base) ---

model DocPage {
  id             String    @id @default(cuid())
  tenantId       String
  title          String
  slug           String
  content        String    @db.Text
  excerpt        String?
  parentId       String?
  category       String    @default("General")
  icon           String?
  order          Int       @default(0)
  published      Boolean   @default(false)
  publishedAt    DateTime?
  createdById    String
  lastEditedById String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  archivedAt     DateTime?

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  parent       DocPage?      @relation("DocPageTree", fields: [parentId], references: [id], onDelete: Cascade)
  children     DocPage[]     @relation("DocPageTree")
  createdBy    User          @relation("DocPageCreator", fields: [createdById], references: [id])
  lastEditedBy User?         @relation("DocPageLastEditor", fields: [lastEditedById], references: [id])
  revisions    DocRevision[]

  @@unique([tenantId, slug])
  @@index([tenantId, category, order])
  @@index([tenantId, parentId])
}

model DocRevision {
  id         String   @id @default(cuid())
  docPageId  String
  version    Int
  title      String
  content    String   @db.Text
  changelog  String?
  editedById String
  createdAt  DateTime @default(now())

  docPage  DocPage @relation(fields: [docPageId], references: [id], onDelete: Cascade)
  editedBy User    @relation(fields: [editedById], references: [id])

  @@unique([docPageId, version])
  @@index([docPageId])
}

// --- Statutory Registers ---

model Director {
  id              String    @id @default(cuid())
  tenantId        String
  fullName        String
  title           String?               // Mr, Mrs, Dr, etc.
  designation     String    @default("Director") // Director, Managing Director, Executive Director, Non-Executive Director, Chairman
  nationality     String?
  idNumber        String?               // National ID or passport number
  email           String?
  phone           String?
  residentialAddress String? @db.Text
  dateOfBirth     DateTime?
  appointmentDate DateTime
  cessationDate   DateTime?             // null = currently serving
  cessationReason String?               // resigned, removed, deceased, term_expired
  shareholding    Decimal?  @db.Decimal(5, 2) // percentage ownership if also a shareholder
  notes           String?   @db.Text
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, cessationDate])
}

model Shareholder {
  id              String    @id @default(cuid())
  tenantId        String
  name            String                // person or entity name
  type            String    @default("individual") // individual, corporate, trust, nominee
  nationality     String?
  idNumber        String?               // ID, passport, or registration number
  email           String?
  phone           String?
  address         String?   @db.Text
  sharesHeld      Int                   // number of shares
  shareClass      String    @default("Ordinary") // Ordinary, Preference, etc.
  nominalValue    Decimal?  @db.Decimal(12, 2) // value per share
  percentageHeld  Decimal   @db.Decimal(5, 2) // ownership percentage
  dateAcquired    DateTime
  dateCeased      DateTime?             // null = current shareholder
  transferDetails String?   @db.Text    // notes on how shares were acquired/transferred
  notes           String?   @db.Text
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, dateCeased])
}

// --- HR ---

model Employee {
  id                  String    @id @default(cuid())
  tenantId            String

  employeeNumber      String

  // Personal
  firstName           String
  lastName            String
  middleName          String?
  dateOfBirth         DateTime?
  gender              String?
  nationality         String?
  citizenship         String?
  nationalIdNumber    String?
  taxIdNumber         String?
  photoUrl            String?   @db.Text

  // Contact
  personalEmail       String?
  personalPhone       String?
  homeAddress         String?   @db.Text

  // Emergency contact
  emergencyContactName         String?
  emergencyContactPhone        String?
  emergencyContactRelationship String?

  // Employment
  jobTitle            String?
  department          String?
  unit                String?
  employmentType      String    @default("full_time")
  startDate           DateTime
  endDate             DateTime?
  probationEndDate    DateTime?
  // active, on_leave, suspended, terminated, resigned
  status              String    @default("active")
  // annual, sick, maternity, paternity, study, unpaid, compassionate (used when status = on_leave)
  leaveType           String?
  leaveEndDate        DateTime?
  terminationReason   String?   @db.Text

  // Reporting
  managerId           String?

  // Compensation
  basicSalary         Decimal?  @db.Decimal(12, 2)
  currency            String?   @default("USD")
  payFrequency        String?   @default("monthly")
  bankName            String?
  bankAccountName     String?
  bankAccountNumber   String?

  // Benefits
  hasMedicalAid       Boolean   @default(false)
  medicalAidProvider  String?
  medicalAidPlan      String?
  hasPension          Boolean   @default(false)
  pensionContribution Decimal?  @db.Decimal(5, 2)
  housingAllowance    Decimal?  @db.Decimal(12, 2)
  transportAllowance  Decimal?  @db.Decimal(12, 2)
  otherAllowance      Decimal?  @db.Decimal(12, 2)
  otherAllowanceLabel String?

  // Sizes
  shirtSize           String?
  trouserSize         String?
  shoeSize            String?
  jacketSize          String?

  // Notes
  notes               String?   @db.Text

  userId              String?

  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  tenant        Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  manager       Employee?  @relation("EmployeeManager", fields: [managerId], references: [id], onDelete: SetNull)
  directReports Employee[] @relation("EmployeeManager")
  user          User?      @relation(fields: [userId], references: [id], onDelete: SetNull)
  documents     EmployeeDocument[]
  leaveBalances LeaveBalance[]
  leaveRequests LeaveRequest[]
  payslips      Payslip[]
  expenses      Expense[]
  timesheets    Timesheet[]
  overtimeRequests  OvertimeRequest[]
  reviewedOvertime  OvertimeRequest[] @relation("OvertimeReviewer")
  assetAssignments  AssetAssignment[]

  @@unique([tenantId, employeeNumber])
  @@index([tenantId, status])
  @@index([tenantId, department])
  @@index([managerId])
}

model EmployeeDocument {
  id         String   @id @default(cuid())
  employeeId String
  name       String
  fileUrl    String   @db.Text
  fileSize   Int?
  mimeType   String?
  uploadedAt DateTime @default(now())

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
}

// --- Leave Management ---

model LeaveBalance {
  id         String   @id @default(cuid())
  tenantId   String
  employeeId String
  year       Int
  leaveType  String   // annual, sick, maternity, paternity, study, unpaid, compassionate
  allocated  Int      @default(0)
  used       Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, year, leaveType])
  @@index([tenantId, year])
}

model LeaveRequest {
  id           String    @id @default(cuid())
  tenantId     String
  employeeId   String
  leaveType    String    // annual, sick, maternity, paternity, study, unpaid, compassionate
  startDate    DateTime
  endDate      DateTime
  days         Int
  reason       String?   @db.Text
  // pending, approved, rejected, cancelled
  status       String    @default("pending")
  reviewedById String?
  reviewNote   String?   @db.Text
  reviewedAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  reviewedBy User?    @relation(fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([tenantId, status])
  @@index([employeeId, status])
  @@index([tenantId, startDate, endDate])
}

// --- Leave Settings ---

model LeaveSettings {
  id        String @id @default(cuid())
  tenantId  String @unique

  // Maternity
  maternityLeaveDays            Int     @default(180) // 6 months ≈ 180 calendar days
  maternityCanCombineWithAnnual Boolean @default(true)

  // Paternity
  paternityLeaveDays            Int     @default(10)
  paternityCanCombineWithAnnual Boolean @default(true)

  // Sick leave — accrual model
  sickLeaveAccrualPerMonth Decimal @db.Decimal(4, 2) @default(1.5)

  // Annual leave
  annualLeaveDefaultDays Int  @default(21)
  annualLeaveTiers       Json @default("[]") // AnnualLeaveTier[] — sorted by minYears asc

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model LeaveSettingsLog {
  id        String   @id @default(cuid())
  tenantId  String
  changedById String

  maternityLeaveDays            Int
  maternityCanCombineWithAnnual Boolean
  paternityLeaveDays            Int
  paternityCanCombineWithAnnual Boolean
  sickLeaveAccrualPerMonth      Decimal @db.Decimal(4, 2)
  annualLeaveDefaultDays        Int
  annualLeaveTiers              Json    @default("[]")

  createdAt DateTime @default(now())

  tenant    Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  changedBy User   @relation(fields: [changedById], references: [id])

  @@index([tenantId, createdAt])
}

// --- Payroll ---

model PayrollRun {
  id              String    @id @default(cuid())
  tenantId        String

  periodMonth     Int       // 1–12
  periodYear      Int
  periodLabel     String    // "March 2026" — denormalized for display

  // draft, processing, paid
  status          String    @default("draft")

  currency        String    @default("USD")
  totalGross      Decimal   @db.Decimal(14, 2) @default(0)
  totalDeductions Decimal   @db.Decimal(14, 2) @default(0)
  totalNet        Decimal   @db.Decimal(14, 2) @default(0)
  employeeCount   Int       @default(0)

  notes           String?   @db.Text
  processedAt     DateTime?
  paidAt          DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  payslips Payslip[]

  @@unique([tenantId, periodMonth, periodYear])
  @@index([tenantId, status])
  @@index([tenantId, periodYear, periodMonth])
}

model Payslip {
  id           String @id @default(cuid())
  payrollRunId String
  employeeId   String
  tenantId     String

  // Employee snapshot
  employeeName   String
  employeeNumber String
  jobTitle       String?
  department     String?

  // Earnings
  basicSalary        Decimal @db.Decimal(12, 2) @default(0)
  housingAllowance   Decimal @db.Decimal(12, 2) @default(0)
  transportAllowance Decimal @db.Decimal(12, 2) @default(0)
  otherAllowance     Decimal @db.Decimal(12, 2) @default(0)
  otherAllowanceLabel String?
  overtimeHours      Decimal @db.Decimal(5, 2)  @default(0)
  overtimeRate       Decimal @db.Decimal(12, 2) @default(0)
  overtimePay        Decimal @db.Decimal(12, 2) @default(0)
  grossPay           Decimal @db.Decimal(12, 2) @default(0)

  // Deductions
  pensionRate           Decimal @db.Decimal(5, 2)  @default(0)
  pensionContribution   Decimal @db.Decimal(12, 2) @default(0)
  medicalAidDeduction   Decimal @db.Decimal(12, 2) @default(0)
  payeTax               Decimal @db.Decimal(12, 2) @default(0)
  otherDeduction        Decimal @db.Decimal(12, 2) @default(0)
  otherDeductionLabel   String?
  totalDeductions       Decimal @db.Decimal(12, 2) @default(0)

  netPay   Decimal @db.Decimal(12, 2) @default(0)
  currency String  @default("USD")

  // Bank snapshot
  bankName          String?
  bankAccountName   String?
  bankAccountNumber String?

  // pending, processed, paid
  status String @default("pending")
  notes  String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  payrollRun PayrollRun @relation(fields: [payrollRunId], references: [id], onDelete: Cascade)
  employee   Employee   @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  tenant     Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([payrollRunId, employeeId])
  @@index([tenantId, status])
  @@index([employeeId])
  @@index([payrollRunId, status])
}

// --- Expenses ---

model ExpenseCategory {
  id        String   @id @default(cuid())
  value     String   @unique
  label     String
  isSystem  Boolean  @default(true)
  createdAt DateTime @default(now())

  expenses Expense[]
}

model Expense {
  id            String  @id @default(cuid())
  tenantId      String
  employeeId    String?
  submittedById String

  title       String
  description String?  @db.Text
  amount      Decimal  @db.Decimal(12, 2)
  currency    String   @default("USD")
  categoryId  String
  expenseDate DateTime

  receiptUrl String? @db.Text

  // draft, submitted, approved, rejected, reimbursed
  status String @default("draft")

  notes        String?   @db.Text
  reviewedById String?
  reviewedAt   DateTime?
  reimbursedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant      Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employee    Employee?       @relation(fields: [employeeId], references: [id], onDelete: SetNull)
  submittedBy User            @relation("ExpenseSubmitter", fields: [submittedById], references: [id], onDelete: Cascade)
  reviewedBy  User?           @relation("ExpenseReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  category    ExpenseCategory @relation(fields: [categoryId], references: [id])

  @@index([tenantId, status])
  @@index([tenantId, categoryId])
  @@index([tenantId, employeeId])
  @@index([tenantId, expenseDate])
}

// --- Bills & Vendors ---

model Vendor {
  id          String  @id @default(cuid())
  tenantId    String
  name        String
  contactName String?
  email       String?
  phone       String?
  address     String? @db.Text
  website     String?

  paymentTerms String @default("net30") // net15, net30, net60, due_on_receipt

  bankName          String?
  bankAccountName   String?
  bankAccountNumber String?
  bankBranch        String?

  notes  String? @db.Text
  status String  @default("active") // active, inactive

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  bills          Bill[]
  purchaseOrders PurchaseOrder[]

  @@index([tenantId, status])
  @@index([tenantId, name])
}

model Bill {
  id      String @id @default(cuid())
  tenantId String
  vendorId String

  billNumber      String
  referenceNumber String?
  title           String
  description     String? @db.Text

  subtotal    Decimal  @db.Decimal(12, 2) @default(0)
  taxRate     Decimal? @db.Decimal(5, 2)
  taxAmount   Decimal  @db.Decimal(12, 2) @default(0)
  totalAmount Decimal  @db.Decimal(12, 2) @default(0)
  amountPaid  Decimal  @db.Decimal(12, 2) @default(0)
  amountDue   Decimal  @db.Decimal(12, 2) @default(0)
  currency    String   @default("GMD")

  issueDate DateTime @default(now())
  dueDate   DateTime
  paidAt    DateTime?

  // draft, approved, partially_paid, paid, overdue, void
  status String @default("draft")

  notes String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  vendor        Vendor         @relation(fields: [vendorId], references: [id], onDelete: Restrict)
  payments      BillPayment[]
  purchaseOrder PurchaseOrder?

  @@unique([tenantId, billNumber])
  @@index([tenantId, status])
  @@index([tenantId, vendorId])
  @@index([tenantId, dueDate])
}

model BillPayment {
  id            String   @id @default(cuid())
  billId        String
  tenantId      String
  amount        Decimal  @db.Decimal(12, 2)
  paymentDate   DateTime @default(now())
  paymentMethod String?
  reference     String?
  notes         String?  @db.Text
  createdAt     DateTime @default(now())

  bill   Bill   @relation(fields: [billId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([billId])
  @@index([tenantId])
}

model BillSettings {
  id             String @id @default(cuid())
  tenantId       String @unique
  billPrefix     String @default("BILL")
  nextBillNumber Int    @default(1)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

// --- Timesheets ---

model Timesheet {
  id         String   @id @default(cuid())
  tenantId   String
  employeeId String
  weekStart  DateTime @db.Date // UTC Monday

  status     String  @default("draft") // draft, submitted, approved, rejected
  totalHours Decimal @db.Decimal(5, 2) @default(0)

  notes        String?   @db.Text // reviewer notes
  submittedAt  DateTime?
  reviewedById String?
  reviewedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant     Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employee   Employee        @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  reviewedBy User?           @relation("TimesheetReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  entries    TimesheetEntry[]

  @@unique([tenantId, employeeId, weekStart])
  @@index([tenantId, status])
  @@index([tenantId, weekStart])
  @@index([employeeId])
}

model TimesheetEntry {
  id          String   @id @default(cuid())
  timesheetId String
  date        DateTime @db.Date
  hours       Decimal  @db.Decimal(5, 2)
  category    String   @default("work") // work, meeting, training, admin, travel, sick, other
  projectId   String?
  description String?  @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  timesheet Timesheet @relation(fields: [timesheetId], references: [id], onDelete: Cascade)
  project   Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([timesheetId])
  @@index([timesheetId, date])
}

// --- Overtime ---

model OvertimeSettings {
  id                     String  @id @default(cuid())
  tenantId               String  @unique
  standardRateMultiplier Decimal @db.Decimal(5, 2) @default(1.5)
  weekendRateMultiplier  Decimal @db.Decimal(5, 2) @default(2.0)
  holidayRateMultiplier  Decimal @db.Decimal(5, 2) @default(2.5)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model OvertimeSettingsLog {
  id                     String   @id @default(cuid())
  tenantId               String
  changedById            String   // User.id
  standardRateMultiplier Decimal  @db.Decimal(5, 2)
  weekendRateMultiplier  Decimal  @db.Decimal(5, 2)
  holidayRateMultiplier  Decimal  @db.Decimal(5, 2)
  createdAt              DateTime @default(now())

  tenant    Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  changedBy User   @relation(fields: [changedById], references: [id])

  @@index([tenantId, createdAt])
}

model OvertimeRequest {
  id           String    @id @default(cuid())
  tenantId     String
  employeeId   String

  date         DateTime  @db.Date
  hours        Decimal   @db.Decimal(5, 2)
  // standard, weekend, holiday
  overtimeType String    @default("standard")
  reason       String    @db.Text

  projectId    String?

  // Snapshotted at approval time — never changes after approval
  appliedRateMultiplier Decimal? @db.Decimal(5, 2)
  calculatedPay         Decimal? @db.Decimal(12, 2)

  // pending, approved, rejected
  status       String    @default("pending")
  reviewedById String?   // Employee.id of the manager who reviewed
  reviewNote   String?   @db.Text
  reviewedAt   DateTime?

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  tenant     Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employee   Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  reviewer   Employee? @relation("OvertimeReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  project    Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([tenantId, status])
  @@index([employeeId, status])
  @@index([tenantId, date])
}

// --- Procurement ---

model ProcurementSettings {
  id                    String @id @default(cuid())
  tenantId              String @unique
  requisitionPrefix     String @default("REQ")
  nextRequisitionNumber Int    @default(1)
  poPrefix              String @default("PO")
  nextPoNumber          Int    @default(1)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model PurchaseRequisition {
  id                String    @id @default(cuid())
  tenantId          String
  requisitionNumber String
  title             String
  description       String?   @db.Text
  requestedById     String
  department        String?
  priority          String    @default("normal") // low, normal, high, urgent
  status            String    @default("draft")  // draft, pending_approval, approved, rejected, converted, cancelled
  requiredByDate    DateTime?
  notes             String?   @db.Text
  reviewedById      String?
  reviewNote        String?   @db.Text
  reviewedAt        DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  tenant         Tenant                    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  requestedBy    User                      @relation("RequisitionRequester", fields: [requestedById], references: [id])
  reviewedBy     User?                     @relation("RequisitionReviewer", fields: [reviewedById], references: [id])
  items          PurchaseRequisitionItem[]
  purchaseOrders PurchaseOrder[]

  @@unique([tenantId, requisitionNumber])
  @@index([tenantId, status])
  @@index([tenantId, requestedById])
}

model PurchaseRequisitionItem {
  id              String   @id @default(cuid())
  requisitionId   String
  description     String
  quantity        Decimal  @db.Decimal(12, 2)
  unit            String?
  estimatedUnitPrice Decimal? @db.Decimal(12, 2)
  estimatedTotal  Decimal? @db.Decimal(12, 2)
  order           Int      @default(0)

  requisition PurchaseRequisition @relation(fields: [requisitionId], references: [id], onDelete: Cascade)

  @@index([requisitionId])
}

model PurchaseOrder {
  id               String    @id @default(cuid())
  tenantId         String
  vendorId         String
  requisitionId    String?
  poNumber         String
  title            String
  description      String?   @db.Text
  currency         String    @default("GMD")
  subtotal         Decimal   @db.Decimal(12, 2) @default(0)
  taxRate          Decimal?  @db.Decimal(5, 2)
  taxAmount        Decimal   @db.Decimal(12, 2) @default(0)
  totalAmount      Decimal   @db.Decimal(12, 2) @default(0)
  status           String    @default("draft") // draft, sent, partially_received, received, billed, cancelled
  issueDate        DateTime  @default(now())
  expectedDelivery DateTime?
  receivedDate     DateTime?
  billId           String?   @unique
  notes            String?   @db.Text
  createdById      String
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  tenant       Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  vendor       Vendor               @relation(fields: [vendorId], references: [id], onDelete: Restrict)
  requisition  PurchaseRequisition? @relation(fields: [requisitionId], references: [id], onDelete: SetNull)
  bill         Bill?                @relation(fields: [billId], references: [id], onDelete: SetNull)
  createdBy    User                 @relation(fields: [createdById], references: [id])
  items        PurchaseOrderItem[]
  goodsReceipts GoodsReceipt[]
  assets       Asset[]

  @@unique([tenantId, poNumber])
  @@index([tenantId, status])
  @@index([tenantId, vendorId])
}

model PurchaseOrderItem {
  id               String  @id @default(cuid())
  purchaseOrderId  String
  description      String
  quantity         Decimal @db.Decimal(12, 2)
  unit             String?
  unitPrice        Decimal @db.Decimal(12, 2)
  totalPrice       Decimal @db.Decimal(12, 2)
  quantityReceived Decimal @db.Decimal(12, 2) @default(0)
  order            Int     @default(0)

  purchaseOrder    PurchaseOrder      @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  goodsReceiptItems GoodsReceiptItem[]

  @@index([purchaseOrderId])
}

model GoodsReceipt {
  id              String   @id @default(cuid())
  tenantId        String
  purchaseOrderId String
  receiptNumber   String
  receivedDate    DateTime @default(now())
  receivedById    String
  notes           String?  @db.Text
  createdAt       DateTime @default(now())

  tenant        Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  purchaseOrder PurchaseOrder      @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  receivedBy    User               @relation(fields: [receivedById], references: [id])
  items         GoodsReceiptItem[]

  @@index([tenantId])
  @@index([purchaseOrderId])
}

model GoodsReceiptItem {
  id               String  @id @default(cuid())
  goodsReceiptId   String
  poItemId         String
  quantityReceived Decimal @db.Decimal(12, 2)
  notes            String?

  goodsReceipt GoodsReceipt      @relation(fields: [goodsReceiptId], references: [id], onDelete: Cascade)
  poItem       PurchaseOrderItem @relation(fields: [poItemId], references: [id], onDelete: Cascade)

  @@index([goodsReceiptId])
}

// --- Assets ---

model AssetSettings {
  id              String @id @default(cuid())
  tenantId        String @unique
  assetPrefix     String @default("AST")
  nextAssetNumber Int    @default(1)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model Asset {
  id                 String    @id @default(cuid())
  tenantId           String
  assetNumber        String
  name               String
  description        String?   @db.Text
  category           String    @default("equipment") // equipment, furniture, vehicle, technology, office_supplies, other
  status             String    @default("active")    // active, in_maintenance, disposed, lost, retired
  serialNumber       String?
  brand              String?
  model              String?
  location           String?
  purchaseDate       DateTime?
  purchasePrice      Decimal?  @db.Decimal(12, 2)
  currency           String    @default("GMD")
  warrantyExpiry     DateTime?
  condition          String    @default("good") // new, good, fair, poor
  currentValue       Decimal?  @db.Decimal(12, 2)
  depreciationMethod String?   // straight_line, declining_balance, none
  usefulLifeMonths   Int?
  salvageValue       Decimal?  @db.Decimal(12, 2)
  notes              String?   @db.Text
  purchaseOrderId    String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  tenant        Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  purchaseOrder PurchaseOrder?    @relation(fields: [purchaseOrderId], references: [id], onDelete: SetNull)
  assignments   AssetAssignment[]
  maintenance   AssetMaintenance[]

  @@unique([tenantId, assetNumber])
  @@index([tenantId, status])
  @@index([tenantId, category])
}

model AssetAssignment {
  id           String    @id @default(cuid())
  assetId      String
  employeeId   String?
  location     String?
  assignedDate DateTime  @default(now())
  returnedDate DateTime?
  notes        String?
  assignedById String
  createdAt    DateTime  @default(now())

  asset      Asset     @relation(fields: [assetId], references: [id], onDelete: Cascade)
  employee   Employee? @relation(fields: [employeeId], references: [id], onDelete: SetNull)
  assignedBy User      @relation("AssetAssigner", fields: [assignedById], references: [id])

  @@index([assetId])
  @@index([employeeId])
}

model AssetMaintenance {
  id                  String    @id @default(cuid())
  assetId             String
  title               String
  description         String?   @db.Text
  maintenanceDate     DateTime
  nextMaintenanceDate DateTime?
  cost                Decimal?  @db.Decimal(12, 2)
  currency            String    @default("GMD")
  performedBy         String?
  status              String    @default("completed") // scheduled, in_progress, completed
  createdAt           DateTime  @default(now())

  asset Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([assetId])
}
