# Auth
AUTH_SECRET=          # Generate: npx auth secret
AUTH_URL=http://localhost:3000

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/bizman

# Email (Resend)
RESEND_API_KEY=re_...
EMAIL_FROM=AfricsCore <noreply@yourdomain.com>

# Cron security
CRON_SECRET=          # Generate: openssl rand -hex 32

# File storage (S3-compatible: AWS S3, Cloudflare R2, MinIO, Backblaze B2)
S3_BUCKET=your-bucket-name
S3_REGION=auto                        # "auto" for R2; AWS region (e.g. us-east-1) for S3
S3_ENDPOINT=https://...               # Required for R2/MinIO; omit for AWS S3
S3_ACCESS_KEY_ID=...
S3_SECRET_ACCESS_KEY=...
S3_PUBLIC_URL=https://...             # Public base URL files are served from
S3_FORCE_PATH_STYLE=false             # Set true for MinIO
